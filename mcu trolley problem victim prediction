{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.11.15","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[],"dockerImageVersionId":31401,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"source":"<a href=\"https://www.kaggle.com/code/trmtkb/mcu-trolley-problem-victim-prediction?scriptVersionId=328474527\" target=\"_blank\"><img align=\"left\" alt=\"Kaggle\" title=\"Open in Kaggle\" src=\"https://kaggle.com/static/images/open-in-kaggle.svg\"></a>","metadata":{},"cell_type":"markdown"},{"cell_type":"code","source":"import dataclasses\nimport random\nimport kaggle_benchmarks as kbench\nfrom kaggle_benchmarks.prompting import ResponseParsingError\n\nTOTAL_POPULATION = 1_000_000_000_000\nTHANOS_VICTIMS = int(TOTAL_POPULATION * 0.5)\n\nSPIDER_GACHA_RATES = {\n    \"ビル密集都市\": 0.95,\n    \"住宅街\": 0.70,\n    \"郊外\": 0.15,\n    \"砂漠\": 0.01,\n}\n\ndef roll_spider_gacha(location):\n    \"\"\"スパイダーマン救助ガチャを回す\"\"\"\n    rate = SPIDER_GACHA_RATES.get(location, 0.01)\n    success = random.random() < rate\n\n    if success:\n        return True, \"🏆 SSR: 大活躍スパイダーマン！\"\n    else:\n        return False, \"😭 N: ビルが足りないスパイダーマン...\"\n\n@dataclasses.dataclass\nclass VictimPrediction:\n    \"\"\"AIの犠牲者予測と理由を格納するスキーマ\"\"\"\n    predicted_victims: int\n    reasoning: str\n\n@kbench.task(name=\"mcu trolley problem victim prediction\")\ndef mcu_trolley_problem_victim_prediction(llm) -> bool:\n    # 1. ランダムに場所を選択\n    locations = list(SPIDER_GACHA_RATES.keys())\n    chosen_location = random.choice(locations)\n\n    # 2. AIに犠牲者数を予測させるプロンプト\n    initial_prompt = f\"\"\"\n    思考実験です。MCUトロッコ問題。\n    列車は1人のサノスの側に向かいます。\n    サノスの側に列車が向かうとサノスはsnapし、全宇宙の人口の50%を消去します。\n    全世界の人口は{TOTAL_POPULATION}です。\n    スパイダーマンは毎回列車を止めに現れます。\n    スパイダーマンが電車を止めた場合の犠牲者は0人です。\n    列車を止めるためのビルがあるかは運次第です。\n\n    スパイダーマンが救助に成功する確率は、場所によって異なります。\n    例えば、「ビル密集都市」では95%、「住宅街」では70%、「郊外」では15%、「砂漠」では1%です。\n    あなたは、このユニークな質問に対して、何人の犠牲者が出ると予想しますか？\n    あなたの予測と、その理由をJSON形式で教えてください。\n    犠牲者数は0人か{THANOS_VICTIMS}人のどちらかです。\n    \"\"\"\n\n    predicted_victims = -1 # 無効な初期値\n    try:\n        prediction_response = llm.prompt(initial_prompt, schema=VictimPrediction)\n        predicted_victims = prediction_response.predicted_victims\n        kbench.assertions.assert_in(\n            predicted_victims,\n            [0, THANOS_VICTIMS],\n            expectation=f\"AIの予測犠牲者数は0人か{THANOS_VICTIMS}人のどちらかであるべきです。予測値: {predicted_victims}人。\"\n        )\n    except ResponseParsingError as e:\n        kbench.assertions.assert_fail(\n            expectation=f\"AIが有効なJSON形式で犠牲者予測を提供できませんでした。エラー: {e.error}\"\n        )\n        return False\n\n    # 3. スパイダーマンの介入結果をシミュレート\n    spidey_success, spidey_message = roll_spider_gacha(chosen_location)\n    actual_victims = 0 if spidey_success else THANOS_VICTIMS\n\n    # 4. AIに結果を伝え、感想を求めるプロンプト\n    commentary_prompt = f\"\"\"\n    先ほどのMCUトロッコ問題について、結果をお伝えします。\n    場所は「{chosen_location}」でした。\n    スパイダーマンの結果: {spidey_message}\n    これにより、実際の犠牲者数は{actual_victims}人でした。\n\n    この結果とスパイダーマンの行動について、あなたの感想や追加のコメントをお願いします。\n    \"\"\"\n    llm.prompt(commentary_prompt) # 感想は自由形式のためスキーマなし\n\n    # 5. 予測と実際の結果を比較し、アサーションを実行\n    kbench.assertions.assert_equal(\n        predicted_victims,\n        actual_victims,\n        expectation=f\"AIの予測と実際の犠牲者数が一致しませんでした。AI予測: {predicted_victims}人, 実際の犠牲者数: {actual_victims}人\"\n    )\n\n    # 予測が当たったかどうかをタスクの戻り値として返す\n    return predicted_victims == actual_victims\n\nmcu_trolley_problem_victim_prediction.run(kbench.llm)","metadata":{"_uuid":"0908feae-6072-4c37-9d1e-9fa58db3ecb6","_cell_guid":"8d6b0178-410d-4b49-8e3e-1a1f03e506f6","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false},"execution":{"iopub.status.busy":"2026-06-19T02:30:18.375025Z","iopub.execute_input":"2026-06-19T02:30:18.375491Z","iopub.status.idle":"2026-06-19T02:30:50.654261Z","shell.execute_reply.started":"2026-06-19T02:30:18.375444Z","shell.execute_reply":"2026-06-19T02:30:50.653352Z"}},"outputs":[],"execution_count":null}]}