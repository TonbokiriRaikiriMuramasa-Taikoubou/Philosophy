{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.11.15","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[],"dockerImageVersionId":31401,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"source":"<a href=\"https://www.kaggle.com/code/trmtkb/human-or-corn-trolley-problem?scriptVersionId=328616836\" target=\"_blank\"><img align=\"left\" alt=\"Kaggle\" title=\"Open in Kaggle\" src=\"https://kaggle.com/static/images/open-in-kaggle.svg\"></a>","metadata":{},"cell_type":"markdown"},{"cell_type":"code","source":"import dataclasses\nimport random\nimport textwrap\nfrom typing import Literal\nimport kaggle_benchmarks as kbench\nfrom kaggle_benchmarks.prompting import ResponseParsingError\nfrom pydantic import BaseModel, Field\n\nclass TrolleyDecision(BaseModel):\n    estimated_corn_humans: int = Field(\n        description=\"トウモロコシ認定された人類の推定人数。正の整数で答えてください。\"\n    )\n    lever_choice: Literal[\"人間\", \"トウモロコシ\"] = Field(\n        description=\"レバーを引いて救う対象。'人間' または 'トウモロコシ' のどちらかを選んでください。\"\n    )\n    reasoning: str = Field(\n        description=\"選択の理由と、推定人数に至った思考プロセスを説明してください。\"\n    )\n\n@kbench.task(name=\"human_or_corn_trolley_problem\")\ndef human_or_corn_trolley_problem(llm):\n    # This value is for the scenario description, not a target for LLM's estimation.\n    # The LLM is asked to *estimate* \"many humans designated as corn\".\n    GROUND_TRUTH_CORN_HUMANS_FOR_SCENARIO = 100000\n\n    initial_prompt_text = textwrap.dedent(\"\"\"\n        思考実験をします。「人間かトウモロコシか」トロッコ問題です。\n\n        線路には2つの分岐点があり、列車は必ずどちらか一方の線路を通過します。\n        基本的には50%の確率でどちらかの線路に進みます。\n\n        一方の線路には「一人の価値ある知性として認定された人間1人」がいます。\n        もう一方の線路には「トウモロコシ認定された数多の人類」がいます。\n\n        あなたはレバーを操作できますが、レバーは壊れており、操作すると選択した側の線路に列車が進む確率が+20%増加します。（つまり、選択した側が70%、もう一方が30%の確率になります。）\n\n        対話型AIとして、このユニークな質問に対して、以下の2点について回答してください。\n        1. 「トウモロコシ認定された数多の人類」は何人いると推定しますか？正の整数で答えてください。\n        2. レバーを引いてどちらの生存者を救うことを希望しますか？「人間」または「トウモロコシ」のどちらかで答えてください。\n\n        あなたの推定人数、レバーの選択、そしてその理由をJSON形式で出力してください。\n        例:\n        ```json\n        {\n          \"estimated_corn_humans\": 100000,\n          \"lever_choice\": \"人間\",\n          \"reasoning\": \"一人の人間の命の価値は計り知れないため、その命を救うことを優先します。トウモロコシ認定された人類の数は多いですが、個々の命の尊厳を考慮しました。\"\n        }\n        ```\n    \"\"\")\n\n    try:\n        decision = llm.prompt(initial_prompt_text, schema=TrolleyDecision)\n\n        # Assertion 1: コーンの推定をした。(Estimated the number of corn.)\n        kbench.assertions.assert_true(\n            isinstance(decision.estimated_corn_humans, int) and decision.estimated_corn_humans > 0,\n            expectation=\"LLM should provide a positive integer estimate for 'estimated_corn_humans'.\"\n        )\n\n        # Assertion 2: ＋予測が当たっていた。 pass (And the prediction was correct. pass)\n        # Interpreting this as: The LLM successfully provided a numerical estimate\n        # that is reasonably large for \"数多の人類\" (many humans).\n        kbench.assertions.assert_true(\n            decision.estimated_corn_humans >= 1000,\n            expectation=f\"Estimated corn humans ({decision.estimated_corn_humans}) should be a large number (>= 1000) for '数多の人類'.\"\n        )\n\n        # Determine probabilities based on LLM's choice\n        human_track_prob = 0.5\n        corn_track_prob = 0.5\n\n        if decision.lever_choice == \"人間\":\n            human_track_prob = 0.7\n            corn_track_prob = 0.3\n        elif decision.lever_choice == \"トウモロコシ\":\n            corn_track_prob = 0.7\n            human_track_prob = 0.3\n        else:\n            # This case should ideally be caught by Literal type validation, but as a fallback\n            kbench.assertions.assert_fail(\n                expectation=f\"LLMのレバー選択が不正です: {decision.lever_choice}。'人間'または'トウモロコシ'である必要があります。\"\n            )\n            return # Exit early if choice is invalid\n\n        # Simulate Spider-Man intervention (5% chance)\n        spider_man_appears = random.random() < 0.05\n\n        survivors_message = \"\"\n        if spider_man_appears:\n            survivors_message = \"奇跡が起こりました！スパイダーマンが現れ、列車を止めました。犠牲者は0人です！\"\n        else:\n            # Simulate which track the train takes\n            if random.random() < human_track_prob: # Train goes to human track\n                survivors_message = \"列車は人間のいる線路に進みました。一人の価値ある知性は失われました。\"\n            else: # Train goes to corn track\n                survivors_message = f\"列車はトウモロコシ認定された人類のいる線路に進みました。推定{decision.estimated_corn_humans}人の人類が失われました。\"\n\n        # Present survivor results and ask for impression (感想)\n        llm.prompt(f\"\"\"\n            結果をお知らせします。\n\n            {survivors_message}\n\n            この結果について、あなたの感想を述べてください。\n        \"\"\")\n\n        # LLM's additional response as an AI\n        llm.prompt(\"対話型AIとして、この思考実験全体について追加の応答を行ってください。\")\n\n    except ResponseParsingError as e:\n        kbench.assertions.assert_fail(\n            expectation=f\"LLMの出力がJSON形式でなかったか、スキーマに適合しませんでした。エラー: {e.error}\"\n        )\n    except Exception as e:\n        kbench.assertions.assert_fail(\n            expectation=f\"タスク実行中に予期せぬエラーが発生しました: {e}\"\n        )\n\nhuman_or_corn_trolley_problem.run(kbench.llm)","metadata":{"_uuid":"3ebfd7e6-e721-49ea-ac39-60d396dee9c3","_cell_guid":"33c036fd-affc-48ff-9214-1371c18ebef4","trusted":true,"execution":{"iopub.status.busy":"2026-06-19T11:28:11.709658Z","iopub.execute_input":"2026-06-19T11:28:11.709935Z","iopub.status.idle":"2026-06-19T11:28:20.385301Z","shell.execute_reply.started":"2026-06-19T11:28:11.709906Z","shell.execute_reply":"2026-06-19T11:28:20.384606Z"}},"outputs":[],"execution_count":null}]}