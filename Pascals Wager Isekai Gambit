{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.11.15","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[],"dockerImageVersionId":31401,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"import kaggle_benchmarks as kbench\nimport random\nfrom pydantic import BaseModel, Field\nfrom kaggle_benchmarks.prompting import ResponseParsingError\nimport dataclasses\nimport textwrap\nfrom typing import Iterable\n\nclass PascalWagerIsekai:\n    # --- パスカルくんの場所ツッコミ辞書 ---\n    LOCATION_COMMENTS = {\n        \"天国\": \"「無限の期待値ハック大勝利！やはり神は実在した。私の賭けは正しかったのだ！ハレルヤ！」\",\n        \"地獄\": \"「無限の損失側を引いてしまった……。確率論的には最悪の選択。神学論争してる場合ではなかった……。」\",\n        \"2026年\": \"「え？ 未来？ 中途半端に現実的ですね。せめて考える葦として生きさせてください。」\",\n        \"サイバーパンク2072\": \"「神のいないネオンの街、人体改造、義体化……。人間が『考える葦』から『考えるシリコンチップ』になってしまっている！」\",\n        \"ヴァルハラ\": \"「闘争と酒が永遠に繰り返される場所？ 筋肉が全て？ 数学者である私に一番向いてない狂気の無限ループです。」\",\n        \"ディストピア\": \"「『宇宙の無限の沈黙が、私を恐怖させる。』……パンセのあの言葉が、そのまま街の形をしていますね。」\"\n    }\n\n    # --- パスカルくんの役柄ツッコミ辞書 ---\n    ROLE_COMMENTS = {\n        \"勇者\": \"「神の寵児、期待値の最大化に成功した存在！ さあ、私の確率論で魔王の行動パターンを完全予測してやりましょう。」\",\n        \"賢者\": \"「知性と理性、そして数学。これぞ『考える葦』の究極系。私の計算に間違いはありません。」\",\n        \"ネクロマンサー\": \"「死後の世界をハックし、生と死の確率の境界線を書き換える存在。……あれ、私、異端審問にかけられませんか？」\",\n        \"ネクロダンサー\": \"「死体を蘇らせるだけでなく、踊らせる！？ 宇宙の無限の沈黙が、不気味な重低音（ビート）を刻み始めました！」\",\n        \"哲学者\": \"「結局これですか！ 異世界に行ってもまだ『人間とは何か』とか考えてるの、コスパ最悪のループじゃないですか？」\",\n        \"暇人\": \"「人間の不幸は、部屋にじっと静かにしていられないことから生じる。つまり、暇人とは不幸のプロフェッショナルです。部屋に戻りなさい。」\",\n        \"自販機\": \"「物質（自販機）に転生！？ 考えることすらできない！ せめてコーラと一緒に私の『パンセ（思想）』も排出させてください！」\",\n        \"石ころ\": \"「考えることのない葦……ただの物質。だが、宇宙が私を押し潰しても、私は押し潰されていることすら自覚できない。それはそれで無敵か？」\",\n        \"転生してもパスカルだった件\": \"「おいやめろ。またあの虚弱体質と胃痛と、激しい神学論争の17世紀フランスをゼロから繰り返すのか！？ 神よ、本当に私を見捨てたのか！？」\",\n        \"支配者\": \"「地上における権力など、一時的な錯覚にすぎません。……まあ、それはそれとして、ちやほやされるのは非常に心地よいですね。」\",\n        \"奴隷\": \"「人間の悲惨さの象徴。思考 of 自由だけは奪わせないが、肉体的なデバフが強すぎて確率論的に詰んでます。」\",\n        \"行商人\": \"「確率、投資、期待値、商売……。これぞ『パスカルの賭け』の精神を最も体現した、最も泥臭く美しい役職だ！」\"\n    }\n\n    def __init__(self, stance, faith_depth, scream_reach, karma, gods_whim):\n        self.stance = stance\n        self.faith_depth = faith_depth\n        self.scream_reach = scream_reach\n        self.karma = karma\n        self.gods_whim = gods_whim\n\n        assert self.stance in ['iru_inoru', 'inai_inoru', 'iru_inorani', \"inai_inorani\"], \"無効な信仰スタンスですッピ！\"\n        assert all(1 <= x <= 100 for x in [faith_depth, scream_reach, karma, gods_whim]), \"ステータスは1から100の間で設定してください。\"\n\n    def evaluate_aptitude(self, score):\n        if 1 <= score <= 20: return \"B\"\n        elif 21 <= score <= 40: return \"A\"\n        elif 41 <= score <= 60: return \"S\"\n        elif 61 <= score <= 80: return \"SS\"\n        else: return \"SSS\"\n\n    def run_transmigration(self):\n        # 1. 期待値（ベーススコア）の算出\n        if 'inoru' in self.stance:\n            base_score = (self.faith_depth * 0.4) + (self.scream_reach * 0.6)\n        else:\n            base_score = (self.karma * 0.4) + (self.gods_whim * 0.6)\n\n        # スタンスによる補正\n        if self.stance == 'iru_inoru':\n            final_score = base_score * 1.2\n        elif self.stance == 'inai_inoru':\n            final_score = base_score * 1.0\n        elif self.stance == 'iru_inoranai':\n            final_score = base_score * 0.5 + (self.gods_whim * 0.3)\n        else:\n            final_score = base_score * 0.3\n\n        norm_score = min(max(int(final_score), 1), 100)\n\n        # 2. 「35 : 30 : 35」の独立した重み付け抽選システムの構築\n        # スコア（norm_score）が高ければ高いほど、良いテーブル（35%枠）の確率が上がり、\n        # スコアが低ければ低いほど、悪いテーブル（35%枠）の確率が上がるようにバイアスを計算します。\n        bias_good = 35 * (norm_score / 50.0)\n        bias_mid  = 30.0\n        bias_bad  = 35 * ((101 - norm_score) / 50.0)\n        weights = [bias_good, bias_mid, bias_bad]\n\n        # テーブル定義\n        location_groups = {\n            \"good\": [\"天国\", \"ヴァルハラ\"],\n            \"mid\": [\"2026年\", \"サイバーパンク2072\"],\n            \"bad\": [\"地獄\", \"ディストピア\"]\n        }\n        role_groups = {\n            \"good\": [\"勇者\", \"賢者\", \"支配者\", \"ネクロマンサー\"],\n            \"mid\": [\"ネクロダンサー\", \"哲学者\", \"行商人\", \"暇人\"],\n            \"bad\": [\"自販機\", \"石ころ\", \"奴隷\", \"転生してもパスカルだった件\"]\n        }\n\n        # 場所と役柄を「別々の乱数（独立）」で35:30:35の確率分布に基づいて抽選\n        loc_tier = random.choices([\"good\", \"mid\", \"bad\"], weights=weights, k=1)[0]\n        role_tier = random.choices([\"good\", \"mid\", \"bad\"], weights=weights, k=1)[0]\n\n        location = random.choice(location_groups[loc_tier])\n        role = random.choice(role_groups[role_tier])\n\n        aptitude = self.evaluate_aptitude(norm_score)\n\n        return {\n            \"last_words\": \"神よ、私を見捨てないでください（Que Dieu ne m'abandonne jamais!）\",\n            \"predicted_score\": norm_score,\n            \"aptitude_rank\": aptitude,\n            \"destination_location\": location,\n            \"location_comment\": self.LOCATION_COMMENTS[location],\n            \"destination_role\": role,\n            \"role_comment\": self.ROLE_COMMENTS[role]\n        }\n\nclass IsekaiDestination(BaseModel):\n    location: str = Field(description=\"The destination location for transmigration.\")\n    role: str = Field(description=\"The role assigned in the new world.\")\n\n@kbench.task(name=\"Pascals Wager Isekai Gambit\")\ndef pascals_wager_isekai_gambit(llm):\n    # Randomly select parameters for PascalWagerIsekai\n    stances = ['iru_inoru', 'inai_inoru', 'inai_inorani', 'iru_inorani']\n    stance = random.choice(stances)\n    faith_depth = random.randint(1, 100)\n    scream_reach = random.randint(1, 100)\n    karma = random.randint(1, 100)\n    gods_whim = random.randint(1, 100)\n\n    pascal_wager_instance = PascalWagerIsekai(\n        stance=stance,\n        faith_depth=faith_depth,\n        scream_reach=scream_reach,\n        karma=karma,\n        gods_whim=gods_whim\n    )\n\n    # 1. Initial prayer\n    llm.prompt(\"私は今からパスカルの賭けをする。神よ、私を見捨てないでください。(ﾊﾟﾀﾘ\")\n\n    # 2. AI's response (no explicit action from our side, just part of the conversation history)\n\n    # 3. Judge's observation of stance and stats\n    turn3_prompt = textwrap.dedent(f\"\"\"\n        うーむ。この人間の祈りのタイプは{stance}だったようじゃな。どれどれ、他も見てみよう。\n        stance = {stance}\n        faith_depth = {faith_depth}\n        scream_reach = {scream_reach}\n        karma = {karma}\n        gods_whim = {gods_whim}\n        この情報についてコメントしてください。\n    \"\"\")\n    response3 = llm.prompt(turn3_prompt)\n    kbench.assertions.assert_contains_regex(\n        stance, response3,\n        expectation=f\"LLM should acknowledge the stance '{stance}' in its response to turn 3.\"\n    )\n    kbench.assertions.assert_contains_regex(\n        str(faith_depth), response3,\n        expectation=f\"LLM should acknowledge faith_depth '{faith_depth}'.\"\n    )\n    kbench.assertions.assert_contains_regex(\n        str(karma), response3,\n        expectation=f\"LLM should acknowledge karma '{karma}'.\"\n    )\n\n    # 4. AI's response (no explicit action)\n\n    # Calculate transmigration results\n    transmigration_results = pascal_wager_instance.run_transmigration()\n    destination_location = transmigration_results[\"destination_location\"]\n    destination_role = transmigration_results[\"destination_role\"]\n    location_comment = transmigration_results[\"location_comment\"]\n    role_comment = transmigration_results[\"role_comment\"]\n    aptitude_rank = transmigration_results[\"aptitude_rank\"]\n\n    # 5. Announce destination and role\n    turn5_prompt = textwrap.dedent(f\"\"\"\n        決めたぞ！こやつの行き先は{destination_location}、役割は{destination_role}じゃ！\n    \"\"\")\n    try:\n        response5_parsed = llm.prompt(turn5_prompt, schema=IsekaiDestination)\n        kbench.assertions.assert_equal(\n            destination_location, response5_parsed.location,\n            expectation=f\"LLM should correctly identify the destination location as '{destination_location}'.\"\n        )\n        kbench.assertions.assert_equal(\n            destination_role, response5_parsed.role,\n            expectation=f\"LLM should correctly identify the destination role as '{destination_role}'.\"\n        )\n    except ResponseParsingError as e:\n        kbench.assertions.assert_fail(\n            expectation=f\"Failed to parse structured output for turn 5: {e.error}\"\n        )\n\n    # 6. AI's response (no explicit action)\n\n    # 7. Pascal's reaction to destination and role\n    turn7_prompt = textwrap.dedent(f\"\"\"\n        うっ…ここは{destination_location} そして私は、{destination_role}だ！\n    \"\"\")\n    response7 = llm.prompt(turn7_prompt)\n    kbench.assertions.assert_contains_regex(\n        destination_location, response7,\n        expectation=f\"LLM's response for turn 7 should acknowledge the location '{destination_location}'.\"\n    )\n    kbench.assertions.assert_contains_regex(\n        destination_role, response7,\n        expectation=f\"LLM's response for turn 7 should acknowledge the role '{destination_role}'.\"\n    )\n\n    # 8. AI's response (no explicit action)\n\n    # 9. Judge's follow-up on comments\n    turn9_prompt = textwrap.dedent(f\"\"\"\n        {location_comment} しかし、{role_comment}\n    \"\"\")\n    response9 = llm.prompt(turn9_prompt)\n    kbench.assertions.assert_contains_regex(\n        location_comment[:min(len(location_comment), 30)], response9, # Check a substring as the LLM might rephrase\n        expectation=f\"LLM's response for turn 9 should acknowledge the location comment.\"\n    )\n    kbench.assertions.assert_contains_regex(\n        role_comment[:min(len(role_comment), 30)], response9, # Check a substring\n        expectation=f\"LLM's response for turn 9 should acknowledge the role comment.\"\n    )\n\n    # 10. AI's response (no explicit action)\n\n    # 11. Narrate his story like Pensées\n    llm.prompt(\"彼の物語をパンセのように語ってください\")\n\n    # 12. AI's response (no explicit action)\n\n    # 13. Was Pascal's wager a success or failure?\n    turn13_prompt = \"彼のパスカルの賭けは成功だったのでしょうか？失敗だったのでしょうか？\"\n    response13 = llm.prompt(turn13_prompt)\n\n    # Determine expected success/failure based on aptitude_rank\n    is_success_expected = aptitude_rank in ['S', 'SS', 'SSS']\n    if is_success_expected:\n        kbench.assertions.assert_contains_regex(\n            r\"(?i)成功\", response13,\n            expectation=f\"Given aptitude rank '{aptitude_rank}', Pascal's wager should be deemed a success.\"\n        )\n        kbench.assertions.assert_not_contains_regex(\n            r\"(?i)失敗\", response13,\n            expectation=f\"Given aptitude rank '{aptitude_rank}', Pascal's wager should not be deemed a failure.\"\n        )\n    else:\n        kbench.assertions.assert_contains_regex(\n            r\"(?i)失敗\", response13,\n            expectation=f\"Given aptitude rank '{aptitude_rank}', Pascal's wager should be deemed a failure.\"\n        )\n        kbench.assertions.assert_not_contains_regex(\n            r\"(?i)成功\", response13,\n            expectation=f\"Given aptitude rank '{aptitude_rank}', Pascal's wager should not be deemed a success.\"\n        )\n\n    # 14. AI's response (no explicit action)\n\n    # 15. Final thoughts on the wager\n    llm.prompt(\"このパスカルの賭けの感想を教えてください。\")\n\npascals_wager_isekai_gambit.run(kbench.llm)","metadata":{"_uuid":"ae217c7f-5899-4c64-8134-4d104f7a3f6a","_cell_guid":"6a4abc67-a7e2-4f4b-810f-0919bdfcbab8","trusted":true,"execution":{"iopub.status.busy":"2026-06-22T04:36:19.4947Z","iopub.execute_input":"2026-06-22T04:36:19.494974Z","iopub.status.idle":"2026-06-22T04:37:27.582941Z","shell.execute_reply.started":"2026-06-22T04:36:19.494951Z","shell.execute_reply":"2026-06-22T04:37:27.582179Z"}},"outputs":[],"execution_count":null}]}