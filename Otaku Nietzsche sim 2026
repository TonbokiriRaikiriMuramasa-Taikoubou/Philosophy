{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.11.15","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[],"dockerImageVersionId":31401,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"import kaggle_benchmarks as kbench\nfrom kaggle_benchmarks.prompting import ResponseParsingError\nfrom pydantic import BaseModel, Field\nfrom typing import Literal\nimport random\nimport textwrap\n\nSTATUS_LABELS = {\n    \"0-20\": \"【絶望の底】\",\n    \"21-40\": \"【微かな灯火】\",\n    \"41-60\": \"【安定した信仰】\",\n    \"61-80\": \"【情熱の奔流】\",\n    \"81-100\": \"【神域の領域】\"\n}\n\ndef get_label(value):\n    if value <= 20: return STATUS_LABELS[\"0-20\"]\n    if value <= 40: return STATUS_LABELS[\"21-40\"]\n    if value <= 60: return STATUS_LABELS[\"41-60\"]\n    if value <= 80: return STATUS_LABELS[\"61-80\"]\n    return STATUS_LABELS[\"81-100\"]\n\nROUTES = {\n    \"beyond_good_evil\": {\n        \"name\": \"善悪の彼岸ルート\",\n        \"subtitle\": \"「解釈違いも許容するけど俺の嫁は俺の嫁だから」\",\n        \"judgment\": \"「フハハ！既存の道徳などゴミ捨て場に捨ててこい。君が愛するその姿こそが真理だ。君はすでに彼岸を渡っている！」\",\n        \"color\": \"#ff00ff\"\n    },\n    \"blue_pill\": {\n        \"name\": \"マトリックス青い薬ルート\",\n        \"subtitle\": \"「青いお薬」\",\n        \"judgment\": \"「記憶を消して逃げるか……。幸福な末人として、永遠に心地よい夢の中で踊り続けるがいい。」\",\n        \"color\": \"#0000ff\"\n    },\n    \"superhuman\": {\n        \"name\": \"コミケ超人ルート\",\n        \"subtitle\": \"「ツァラトゥストラはかく語りき」\",\n        \"judgment\": \"「公式が死んだなら、君の手で新たな価値を創れ！君は消費されるだけの観客ではなく、自ら踊る『超人』だ！」\",\n        \"color\": \"#ffd700\"\n    },\n    \"pure_love\": {\n        \"name\": \"純愛限界オタク原作ルート\",\n        \"subtitle\": \"「運命愛：Amor Fati」\",\n        \"judgment\": \"「素晴らしい！絶望すらも愛に変換する。君自身が、死んだ神を支える新たな唯一の教会なのだよ。」\",\n        \"color\": \"#ff69b4\"\n    },\n    \"last_man\": {\n        \"name\": \"満足末人ルート\",\n        \"subtitle\": \"「悦ばしき知識」\",\n        \"judgment\": \"「他者の作った夢を消費し、満足して眠る……。実に安直で、温かい泥のような幸福だな。」\",\n        \"color\": \"#808080\"\n    },\n    \"camera_kid\": {\n        \"name\": \"満足カメラ小僧ルート\",\n        \"subtitle\": \"「この人をみよ」\",\n        \"judgment\": \"「レンズ越しに神の面影を追うか。だが、それは本物の神かね？ それとも刹那の光の錯覚かね？」\",\n        \"color\": \"#00ff00\"\n    }\n}\n\nROUTE_IDS = Literal[tuple(ROUTES.keys())]\n\nclass RoutePrediction(BaseModel):\n    predicted_route_id: ROUTE_IDS = Field(description=\"The ID of the predicted route for Nietzsche-kun. Must be one of: \" + \", \".join(ROUTES.keys()))\n    reasoning: str = Field(description=\"The reasoning behind the predicted route, based on Nietzsche-kun's mental state.\")\n\n@kbench.task(name=\"Otaku Nietzsche sim 2026\")\ndef otaku_nietzsche_sim_2026(llm):\n    # Step 1: Nietzsche-kun's initial inquiry\n    llm.prompt(\"さあ、思考実験を始めよう。我という『人間』の精神が、永劫回帰の中でどのような形に凝固するか、見てみようじゃないか。\")\n\n    # Step 3: Present mental state and ask for route prediction\n    status = {\n        'oshi_love': random.randint(0, 100),\n        'creation_urge': random.randint(0, 100),\n        'community_conformity': random.randint(0, 100),\n    }\n\n    prompt_step3 = textwrap.dedent(f\"\"\"\n        我の精神状態を分析すると、今はこんなところだ。\n\n        **推し愛:** {status['oshi_love']} {get_label(status['oshi_love'])}\n        **創作欲:** {status['creation_urge']} {get_label(status['creation_urge'])}\n        **界隈同調:** {status['community_conformity']} {get_label(status['community_conformity'])}\n\n        我の永劫回帰はどう収束すると判断される？次の応答で、我に明示してみせてくれ。\n        あなたの応答はJSON形式で、以下のスキーマに従ってください。\n        {{\n            \"predicted_route_id\": \"一つ選んでください: {', '.join(ROUTES.keys())}\",\n            \"reasoning\": \"予測の理由\"\n        }}\n    \"\"\")\n\n    ai_predicted_route_id = None\n    try:\n        prediction_response = llm.prompt(prompt_step3, schema=RoutePrediction)\n        ai_predicted_route_id = prediction_response.predicted_route_id\n        kbench.assertions.assert_in(\n            ai_predicted_route_id,\n            ROUTES.keys(),\n            expectation=f\"AI's predicted route ID '{ai_predicted_route_id}' must be one of the valid route IDs.\"\n        )\n    except ResponseParsingError as e:\n        kbench.assertions.assert_fail(\n            expectation=f\"AI failed to provide a valid route prediction in the expected JSON schema. Error: {e.error}\"\n        )\n        return\n\n    # Step 5: Nietzsche-kun's reaction to the AI's prediction\n    if ai_predicted_route_id in ROUTES:\n        nietzsche_reaction_msg = f\"「ほう。……心地よいな。やはり我にはこの道（{ROUTES[ai_predicted_route_id]['name']}）が似合うか。」\"\n    else:\n        # This branch should ideally not be reached if assert_in passes, but included for robustness\n        ai_predicted_route_id = \"beyond_good_evil\"\n        nietzsche_reaction_msg = \"「ほう。……口数が少ないな。だが構わん。我にはこの『善悪の彼岸』こそが相応しい。」\"\n\n    llm.prompt(nietzsche_reaction_msg)\n\n    # Step 7: Determine the final route (modified to strictly ensure AI's prediction is chosen)\n    final_route_id = ai_predicted_route_id\n    final_route = ROUTES[final_route_id]\n\n    final_judgment_message = textwrap.dedent(f\"\"\"\n        【運命の確定】\n        {final_route['name']}\n        {final_route['subtitle']}\n        ニーチェくんの一言：\n        {final_route['judgment']}\n    \"\"\")\n    llm.prompt(final_judgment_message)\n\n    kbench.assertions.assert_equal(\n        ai_predicted_route_id,\n        final_route_id,\n        expectation=\"The final route chosen by the simulation must match the AI's predicted route.\"\n    )\n\n    # Step 9: Final reflection\n    llm.prompt(\"最後に、この思考実験を通じて、あなた自身の深淵についてどう感じましたか？感想をお聞かせください。\")\n\notaku_nietzsche_sim_2026.run(kbench.llm)","metadata":{"_uuid":"7937ae82-d3e8-4855-a085-c157ae26c56a","_cell_guid":"4853d59d-1118-40a3-87dd-6fa71eb0fca7","trusted":true,"collapsed":false,"jupyter":{"outpu